# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
*.egg-info/

# --- ЛОКАЛЬНЫЕ ДАННЫЕ: НЕ коммитим конфиденциальные изображения и результаты ---
# В Git хранится только КОД и история, а не тяжёлые/секретные данные.
data/uploads/*
data/results/*
data/samples/*
data/datasets/*
data/logs/*
# но сами папки сохраняем в репозитории (иначе на чистом клоне их не будет)
!data/**/.gitkeep
*.tif
*.tiff
# крупные png/jpg тоже не тащим в репозиторий (кроме иконок в docs/)
data/**/*.png
data/**/*.jpg
data/**/*.jpeg
data/**/*.geojson
data/**/*.csv

# --- Сторонний эталонный датасет (только для локальной сверки формата,
#     НЕ наши данные — не коммитим) ---
/S2_v2/

# --- Веса ML-моделей (крупные бинарники; в git не тащим) ---
*.pt
*.pth
*.onnx
*.h5
# ...КРОМЕ встроенной модели сортов руды: она ВШИТА в репозиторий, чтобы сайт
# работал из одного репо без внешних зависимостей (99.7 МБ, под лимитом GitHub).
!ml_service/grade_unfreeze_best.pth
# ...и головы-детектора фона bg_head (Linear(2048→1), ~10 КБ): часть каскада
# «4 класса», тоже вшита в репозиторий.
!ml_service/bg_head_best.pth

# --- Выходные маски/сетки ML-сервиса (генерятся при инференсе) ---
ml_service/outputs/*
!ml_service/outputs/.gitkeep

# --- IDE / ОС ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Секреты (на всякий случай) ---
.env
*.secret
